# MailPush 环境变量示例
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中，不会被提交）
#
# 用法（任选其一）：
#   export MAILPUSH_AI_API_KEY="sk-xxxxxxxxxxxxxxxx"
#   或在 ~/.config/mailpush/config.json 的 ai.api_key 字段填入

# Kimi / OpenAI 兼容 API Key
# 从 https://platform.moonshot.cn 获取
# 将下面的 YOUR_KEY_HERE 替换为真实 key，然后 export 或写入 ~/.config/mailpush/config.json
MAILPUSH_AI_API_KEY=YOUR_KEY_HERE

# 可选：覆盖 API Base URL（默认走本地代理 127.0.0.1:8648）
# MAILPUSH_AI_BASE_URL=https://api.moonshot.cn/v1

# 可选：模型名称
# MAILPUSH_AI_MODEL=moonshot-v1-8k

# MailPush REST API Token（用于 X-API-Token 请求头）
# 建议用 openssl rand -hex 32 生成
# MAILPUSH_API_TOKEN=your-random-token-here
